---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'rinha2-back-end-k6 | IT WORKED ON YOUR MACHINE. NOT ON OURS.',
  description = 'Grafana k6 stress test suite for the Rinha de Backend 2024/Q1 challenge. xk6 + JavaScript, 5 scenarios, 47k+ requests, custom Trend metrics.'
} = Astro.props;

const GA_ID = import.meta.env.PUBLIC_GA_ID;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  'name': 'Rinha de Backend — k6 Stress Tests',
  'description': description,
  'url': 'https://jonathanperis.github.io/rinha2-back-end-k6/',
  'codeRepository': 'https://github.com/jonathanperis/rinha2-back-end-k6',
  'programmingLanguage': 'JavaScript',
  'runtimePlatform': 'Grafana k6 / xk6',
  'license': 'https://github.com/jonathanperis/rinha2-back-end-k6/blob/main/LICENSE',
  'author': {
    '@type': 'Person',
    'name': 'Jonathan Peris',
    'url': 'https://jonathanperis.github.io/'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="keywords" content="k6, xk6, Grafana, stress test, load test, JavaScript, Rinha de Backend, performance, banking API" />
    <link rel="canonical" href="https://jonathanperis.github.io/rinha2-back-end-k6/" />
    <meta name="theme-color" content="#00ff41" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://jonathanperis.github.io/rinha2-back-end-k6/" />
    <meta property="og:site_name" content="rinha2-back-end-k6" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@jperis_silva" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
  </head>
  <body>
    <!-- Google Analytics -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>

    <slot />
  </body>
</html>
