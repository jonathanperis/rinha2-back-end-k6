---
import '../styles/globals.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'rinha2-back-end-k6 | IT WORKED ON YOUR MACHINE. NOT ON OURS.',
  description = 'Grafana k6 stress test suite for the Rinha de Backend 2024/Q1 challenge. xk6 + JavaScript, 5 scenarios, 47k+ requests, custom Trend metrics.'
} = Astro.props;

const pageUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : `https://jonathanperis.github.io${Astro.url.pathname}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  'name': 'Rinha de Backend — k6 Stress Tests',
  'description': description,
  'url': pageUrl,
  'codeRepository': 'https://github.com/jonathanperis/rinha2-back-end-k6',
  'programmingLanguage': 'JavaScript',
  'runtimePlatform': 'Grafana k6 / xk6',
  'license': 'https://github.com/jonathanperis/rinha2-back-end-k6/blob/main/LICENSE',
  'author': {
    '@type': 'Person',
    'name': 'Jonathan Peris',
    'url': 'https://jonathanperis.github.io/'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="keywords" content="k6, xk6, Grafana, stress test, load test, JavaScript, Rinha de Backend, performance, banking API" />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#00ff41" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="rinha2-back-end-k6" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@jperis_silva" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
    <Analytics />
  </head>
  <body>
    <div class="particles" aria-hidden="true">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="data-streams" aria-hidden="true"></div>

    <slot />
  </body>
</html>
